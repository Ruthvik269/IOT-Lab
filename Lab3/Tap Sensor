const int tapSensorPin = 2; 

void setup() {
  pinMode(tapSensorPin, INPUT_PULLUP);
  Serial.begin(9600);
  Serial.println("System Ready. Tap the sensor!");
}

void loop() {
  int tapState = digitalRead(tapSensorPin);
  
  // If the sensor is triggered (LOW)
  if (tapState == LOW) {
    Serial.println(">>> Tap detected!"); 

    delay(200); 
  }
}
